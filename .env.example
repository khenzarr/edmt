# ============================================================
# EDMT/eNAT Mint Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Add .env to your .gitignore immediately.

# --- Ethereum RPC ---
# Use a dedicated private RPC endpoint — public RPCs will rate-limit and cause failures.
# Recommended providers:
#   Alchemy:   https://alchemy.com          (e.g. https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY)
#   Infura:    https://infura.io            (e.g. https://mainnet.infura.io/v3/YOUR_KEY)
#   QuickNode: https://quicknode.com
#   Self-hosted: your own Geth/Erigon/Reth node
# DO NOT use cloudflare-eth.com or other public RPCs for production.
RPC_URL=

# --- Wallet ---
# Private key of the HOT WALLET used for minting.
# ⚠️  WARNING: Use a DEDICATED hot wallet — NEVER your main wallet.
# ⚠️  WARNING: This key is NEVER logged, stored in DB, or printed anywhere.
# ⚠️  WARNING: Keep this file out of version control (.gitignore).
PRIVATE_KEY=

# --- Safety Flags ---
# BOTH must be explicitly set to enable live minting.
# Default: dry-run mode (safe). Set to false only when fully ready.
DRY_RUN=true
# Secondary safety flag. Must ALSO be true for live mint.
ENABLE_LIVE_MINT=false

# --- Scan Range ---
# EIP-1559 activation block on mainnet. Do not go below this.
START_BLOCK=12965000
# Optional upper bound. Leave empty to scan indefinitely.
STOP_BLOCK=
# ascending or descending
SCAN_DIRECTION=ascending

# --- Run Limits ---
MAX_BLOCKS_PER_RUN=1000
# Maximum transactions to send per bot run. Default 1 is safest.
MAX_TX_PER_RUN=1

# --- Timing ---
POLL_INTERVAL_MS=3000

# --- Retry Limits ---
API_RETRY_LIMIT=5
RPC_RETRY_LIMIT=5

# --- Gas Limits (Gwei) ---
# Bot will NOT send tx if network gas exceeds MAX_GAS_GWEI.
MAX_GAS_GWEI=80
MAX_PRIORITY_FEE_GWEI=3

# --- Capture Fee Limit (Gwei) ---
# Maximum capture fee we are willing to pay.
# ⚠️  Overpayment is NOT refunded by the protocol.
# ⚠️  Fee quote is used exactly as returned — no rounding.
MAX_CAPTURE_FEE_GWEI=1000000000

# --- Burn Eligibility ---
# Blocks with burn < MIN_BURN_GWEI are not eligible for minting.
MIN_BURN_GWEI=1

# --- Safety Confirmations ---
# Require manual CLI confirmation ("yes") before the very first live tx.
# Keep this true until you have verified dry-run behaviour.
REQUIRE_MANUAL_CONFIRMATION_FOR_FIRST_TX=true

# Number of block confirmations required for finality.
# 64 is the standard safe finality threshold on Ethereum mainnet.
FINALITY_CONFIRMATIONS=64

# Behaviour when target block is beyond current chain head:
#   wait  — poll until block exists (default, recommended)
#   skip  — skip to next block
#   stop  — halt the bot
BEYOND_HEAD_BEHAVIOR=wait

# If false, bot will NOT send a new tx while any pending tx exists.
# Keep false to prevent nonce conflicts and duplicate submissions.
ALLOW_MULTIPLE_PENDING_TX=false

# --- Database ---
SQLITE_PATH=./edmt-bot.sqlite

# --- EDMT API ---
# ⚠️  NOTE: The /api/v1/blocks/:N endpoint schema is not officially documented.
# ⚠️  Verify block-specific status responses with dry-run before enabling live mint.
# ⚠️  The /api/v1/blocks/:N/fee endpoint may not exist — fee-required blocks will
#     be skipped if this endpoint is unavailable (safe behaviour).
EDMT_BASE_URL=https://www.edmt.io
EDMT_API_BASE_URL=https://www.edmt.io/api/v1

# ============================================================
# Unattended Auto Mint — Recommended Production Profile
# ============================================================
# Bu bölüm, bot'u gözetimsiz (unattended) modda çalıştırmak için
# önerilen production ayarlarını içerir.
#
# Aktivasyon için şu üç flag'in de ayarlanması gerekir:
#   UNATTENDED_AUTO_MINT=true
#   DRY_RUN=false
#   ENABLE_LIVE_MINT=true
#
# ⚠️  Bu mod yalnızca hot wallet bakiyesi 0.001–0.02 ETH aralığında
#     olduğunda güvenlidir. Bakiye bu aralığın dışına çıkarsa bot durur.

# Unattended modu aktif et (varsayılan: false — güvenli)
UNATTENDED_AUTO_MINT=false

# Session başına maksimum tx sayısı (999 = pratikte limitsiz)
AUTO_MINT_MAX_TX_PER_SESSION=999

# Günlük maksimum tx sayısı (son 24 saat, 999 = pratikte limitsiz)
AUTO_MINT_MAX_TX_PER_DAY=999

# Maksimum session süresi (dakika). 480 = 8 saat.
AUTO_MINT_MAX_RUNTIME_MINUTES=480

# Block tarama aralığı (ms). 12000 = ~1 Ethereum block süresi.
AUTO_MINT_POLL_INTERVAL_MS=12000

# Her tx için CLI onayı iste (false = tam otomatik)
AUTO_MINT_CONFIRM_EACH_TX=false

# Hot wallet minimum bakiye (ETH). Bu değerin altına düşerse bot durur.
# 0.001 ETH ≈ ~20 standart tx için gas (80 gwei'de)
AUTO_MINT_MIN_WALLET_BALANCE_ETH=0.001

# Hot wallet maksimum bakiye (ETH). Bu değerin üstüne çıkarsa bot durur.
# Yanlışlıkla fazla fonlama koruması. 0.02 ETH önerilen üst sınır.
AUTO_MINT_REQUIRE_HOT_WALLET_BALANCE_MAX_ETH=0.02

# İlk hata görüldüğünde session'ı durdur (false = hataları atla, devam et)
AUTO_MINT_STOP_ON_FIRST_ERROR=false

# Review required durumunda session'ı durdur (true = güvenli)
AUTO_MINT_STOP_ON_REVIEW_REQUIRED=true

# Fee gerektiren block görüldüğünde session'ı durdur (false = block'u atla, devam et)
AUTO_MINT_STOP_ON_FEE_REQUIRED=false

# Yalnızca fee gerektirmeyen block'ları mint et (true = önerilen)
AUTO_MINT_ONLY_NO_FEE_BLOCKS=true

# İzin verilen başlangıç block numarası (boş = sınırsız)
AUTO_MINT_ALLOWED_START_BLOCK=

# İzin verilen bitiş block numarası (boş = sınırsız)
AUTO_MINT_ALLOWED_STOP_BLOCK=

# Tx sonrası bekleme süresi (ms). 60000 = 1 dakika cooldown.
AUTO_MINT_COOLDOWN_AFTER_TX_MS=60000

# Emergency stop dosyası yolu. Bu dosyayı oluşturunca bot durur.
# Kullanım: touch STOP_AUTOMINT
AUTO_MINT_EMERGENCY_STOP_FILE=./STOP_AUTOMINT

# Session lock dosyası yolu. Aynı anda tek instance garantisi.
AUTO_MINT_SESSION_LOCK_FILE=./automint.lock

# ============================================================
# Pipeline Auto Mint Mode — Yüksek Throughput Profili
# ============================================================
# Pipeline modu, finality beklenmeksizin birden fazla tx'i eş zamanlı
# olarak "uçuşta" tutarak throughput'u önemli ölçüde artırır.
#
# Aktivasyon için şu koşulların TÜMÜ sağlanmalıdır:
#   AUTO_MINT_PIPELINE_MODE=true
#   UNATTENDED_AUTO_MINT=true
#   DRY_RUN=false
#   ENABLE_LIVE_MINT=true
#
# ⚠️  Pipeline modu yalnızca deneyimli operatörler için önerilir.
# ⚠️  Önce sequential modda (pipeline=false) test edin.
# ⚠️  Nonce anomaly veya review_required durumunda bot otomatik durur.

# Pipeline modunu aktif et (varsayılan: false — güvenli sequential mod)
AUTO_MINT_PIPELINE_MODE=false

# Eş zamanlı maksimum pending tx sayısı (status='pending')
# Bu limite ulaşıldığında yeni tx gönderilmez, monitor devam eder.
# Varsayılan: 3
AUTO_MINT_MAX_PENDING_TXS=3

# Eş zamanlı maksimum unfinalized tx sayısı (status IN ('pending','included'))
# Bu limite ulaşıldığında yeni tx gönderilmez, monitor devam eder.
# Varsayılan: 10
AUTO_MINT_MAX_UNFINALIZED_TXS=10

# İki ardışık tx arasındaki minimum bekleme süresi (ms).
# Mempool aşırı yüklenmesini ve nonce çakışmalarını önler.
# Varsayılan: 30000 (30 saniye)
AUTO_MINT_TX_SPACING_MS=30000

# Herhangi bir tx 'failed' durumuna geçtiğinde yeni tx gönderimini durdur.
# true = güvenli (önerilen), false = başarısız tx'i atla, devam et
# Varsayılan: true
AUTO_MINT_STOP_ON_PENDING_TX_FAILURE=true

# TxMonitor reconcile aralığı (ms). Her loop iterasyonunun bekleme süresi.
# ~1 Ethereum block süresi önerilir.
# Varsayılan: 12000 (12 saniye)
AUTO_MINT_RECONCILE_INTERVAL_MS=12000

# Bir sonraki tx göndermeden önce önceki tx'in 'included' durumuna
# geçmesini zorunlu kıl (daha muhafazakâr pipeline davranışı).
# Varsayılan: false
AUTO_MINT_REQUIRE_INCLUDED_BEFORE_NEXT_TX=false

# ============================================================
# High Burn Priority Mint Mode
# ============================================================
# Bu mod, blockları sırayla taramak yerine burn değerine göre
# önceliklendirerek yüksek burn'lü blockları önce mintler.
# Pipeline auto-mint ile birlikte kullanılabilir.
#
# Aktivasyon için:
#   HIGH_BURN_PRIORITY_MODE=true
#   UNATTENDED_AUTO_MINT=true
#   DRY_RUN=false
#   ENABLE_LIVE_MINT=true
#
# ⚠️  Önce highburn:scan ile candidate'ları indexleyin.
# ⚠️  Sonra highburn:mint veya automint ile mintleyin.

# High burn priority modunu aktif et (varsayılan: false)
HIGH_BURN_PRIORITY_MODE=false

# Indexleme başlangıç block numarası (varsayılan: 12965000 = EIP-1559)
HIGH_BURN_SCAN_START_BLOCK=12965000

# Indexleme bitiş block numarası (boş = chain head'e kadar)
HIGH_BURN_SCAN_END_BLOCK=

# Tier bucket sınırları (büyükten küçüğe, virgülle ayrılmış ETH değerleri)
# Her tier bir bucket aralığı tanımlar:
#   100 tier: burnEth >= 100
#   90 tier:  90 <= burnEth < 100
#   50 tier:  50 <= burnEth < 90
#   ... ve böyle devam eder
# Varsayılan: 100,90,50,20,10,5,4,3,2,1,0.5,0.25,0.1
HIGH_BURN_MIN_ETH_TIERS=100,90,50,20,10,5,4,3,2,1,0.5,0.25,0.1

# Session başlangıcında aktif tier (varsayılan: 4 ETH)
# Bot bu tier'dan başlar, exhausted olunca alt tier'a geçer
HIGH_BURN_ACTIVE_TIER_ETH=4

# Her RPC batch'inde işlenecek block sayısı (varsayılan: 1000)
HIGH_BURN_BATCH_SIZE=1000

# Tier başına maksimum candidate sayısı (varsayılan: 10000)
HIGH_BURN_MAX_CANDIDATES_PER_TIER=10000

# Daha önce finalized/minted_elsewhere olan blockları yeniden tara (varsayılan: false)
HIGH_BURN_RESCAN_MINTED=false

# Cache kullan: aynı block için tekrar RPC çağrısı yapma (varsayılan: true)
HIGH_BURN_USE_CACHE=true

# Cache geçerlilik süresi (saat, varsayılan: 168 = 7 gün)
HIGH_BURN_CACHE_TTL_HOURS=168

# Candidate sıralama yönü: desc = yüksek burn önce (varsayılan: desc)
HIGH_BURN_SORT=desc

# Yalnızca EDMT API'nin mintable onayladığı blockları seç (varsayılan: true)
HIGH_BURN_ONLY_MINTABLE=true

# Yalnızca fee gerektirmeyen blockları seç (varsayılan: true)
HIGH_BURN_ONLY_NO_FEE=true

# Daha önce işlenmiş (submitted/finalized/minted_elsewhere) blockları atla (varsayılan: true)
HIGH_BURN_SKIP_ALREADY_SEEN=true

# Tüm tier'lar exhausted olunca davranış:
#   fallback_sequential = normal checkpoint scanner'a dön (varsayılan)
#   wait                = bekle ve tekrar dene
#   stop                = session'ı durdur
HIGH_BURN_ON_EXHAUSTED=fallback_sequential

# Unknown status'taki candidate'ların tekrar denenme aralığı (dakika, varsayılan: 30)
# Bu süre dolmadan unknown candidate tekrar seçilmez
HIGH_BURN_UNKNOWN_RETRY_MINUTES=30
